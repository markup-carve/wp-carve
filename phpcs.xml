<?xml version="1.0"?>
<ruleset name="wpcarve">
    <arg value="nps"/>
    <arg name="colors"/>

    <file>src/</file>
    <file>carve-markup.php</file>
    <file>uninstall.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>

    <rule ref="PhpCollective"/>

    <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInDeclaration"/>
    <rule ref="SlevomatCodingStandard.Functions.RequireTrailingCommaInClosureUse"/>

    <!-- WordPress plugin entry files have side effects by design. -->
    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
        <exclude-pattern>carve-markup.php</exclude-pattern>
        <exclude-pattern>uninstall.php</exclude-pattern>
    </rule>
</ruleset>
